# Optional: override API base (no trailing slash). When unset in dev, the app uses http://localhost:4000/api/v1.
# VITE_API_BASE_URL=http://localhost:4000/api/v1

# Optional: home hero image path under public/ (leading slash). Overrides default priority in src/lib/brand-assets.ts
# VITE_LANDING_HERO=/bg-hero.png
