# Vercel Environment Variables (Project → Settings → Environment Variables)
#
# Required for production (frontend on Vercel, API on Railway):
#   VITE_API_BASE_URL=https://YOUR-SERVICE.up.railway.app/api/v1
#
# Local development (optional — defaults to http://localhost:4000/api/v1):
# VITE_API_BASE_URL=http://localhost:4000/api/v1
#
# Optional hero image under public/:
# VITE_LANDING_HERO=/bg-hero.png

VITE_API_BASE_URL=
